# Eval-runner credentials. Copy to `.env` and fill in:
#   cp .env.example .env
# `.env` is gitignored. NEVER commit the populated file.

# Cursor SDK auth — used by both the agent under test AND the judge.
# Mint a key at https://cursor.com/dashboard/cloud-agents.
CURSOR_API_KEY=

# Optional overrides — leave blank to use defaults.
# Defaults are agent=judge=gemini-3.1-pro with no params.
# Discover available models + their params:
#   pnpm exec tsx scripts/inspect-models.ts [filter]
#
# EVAL_AGENT_MODEL=composer-2
# EVAL_AGENT_PARAMS=fast=false
# EVAL_JUDGE_MODEL=claude-opus-4-6
# EVAL_JUDGE_PARAMS=thinking=true,context=1m,effort=high,fast=false
